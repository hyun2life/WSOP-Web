    {
      "suiteKey": "total",
      "name": "Total Regression (Phase 1~8 Full)",
      "description": "Phase 1~8 전체를 순서대로 실행하는 Full Suite. Phase 1~6은 릴리즈 게이트 기준이며 실패 시 전체 실패 처리. Phase 7~8은 warning/review 처리.",
      "defaultTimeoutMs": 5400000,
      "steps": [
        {
          "phase": "Phase 1",
          "name": "Public Smoke",
          "command": "npm run test:phase1",
          "required": true,
          "allowWarnings": true
        },
        {
