{
  "metadata": {
    "description": "WSOP Web Automation Regression Suite definitions",
    "version": "1.1.0"
  },
  "suites": [
    {
      "suiteKey": "quick",
      "name": "Quick Regression",
      "description": "Fast confidence check for local or pre-merge validation. Keeps only required Phase 1 and Phase 2 gates.",
      "defaultTimeoutMs": 600000,
      "steps": [
        {
          "phase": "Phase 1",
          "name": "Public Smoke",
          "command": "npm run test:phase1",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 2",
          "name": "Functional Flow",
          "command": "npm run test:phase2",
          "required": true,
          "allowWarnings": true
        }
      ]
    },
    {
      "suiteKey": "standard",
      "name": "Standard Regression",
      "description": "Default regression without crawler, visual baseline work, or performance-stability checks.",
      "defaultTimeoutMs": 1800000,
      "steps": [
        {
          "phase": "Phase 1",
          "name": "Public Smoke",
          "command": "npm run test:phase1",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 2",
          "name": "Functional Flow",
          "command": "npm run test:phase2",
          "required": true,
          "allowWarnings": true
        },
