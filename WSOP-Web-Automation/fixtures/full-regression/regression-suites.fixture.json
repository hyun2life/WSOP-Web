          "command": "npm run test:phase4",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 5",
          "name": "Tournament / Result Detail Integrity",
          "command": "npm run test:phase5",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 6",
          "name": "Data / API Integrity",
          "command": "npm run test:phase6",
          "required": true,
          "allowWarnings": true
        }
      ]
    },
    {
      "suiteKey": "extended",
