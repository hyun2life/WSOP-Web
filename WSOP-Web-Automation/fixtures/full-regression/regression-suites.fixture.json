        {
          "phase": "Phase 8",
          "name": "Visual Regression",
          "command": "npm run test:phase8",
          "required": false,
          "allowWarnings": true
        }
      ]
    },
    {
      "suiteKey": "release",
      "name": "Release Regression",
      "description": "Release gate suite. Keeps crawler, visual, and performance checks out of the default release gate.",
      "defaultTimeoutMs": 2400000,
      "steps": [
        {
          "phase": "Phase 1",
          "name": "Public Smoke",
          "command": "npm run test:phase1",
          "required": true,
          "allowWarnings": false
        },
        {
          "phase": "Phase 2",
          "name": "Functional Flow",
          "command": "npm run test:phase2",
          "required": true,
          "allowWarnings": false
        },
        {
          "phase": "Phase 3",
          "name": "Player Presentation & Identity UI",
          "command": "npm run test:phase3",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 5",
          "name": "Tournament / Result Detail Integrity",
          "command": "npm run test:phase5",
          "required": true,
          "allowWarnings": true
        },
        {
          "phase": "Phase 6",
          "name": "Data / API Integrity",
          "command": "npm run test:phase6",
          "required": true,
          "allowWarnings": true
        }
      ]
    },
    {
      "suiteKey": "release-with-visual",
      "name": "Release Regression with Visual",
      "description": "Release regression plus non-blocking visual checks. Baseline updates are never run by this suite.",
      "defaultTimeoutMs": 3600000,
      "extends": "release",
      "additionalSteps": [
        {
          "phase": "Phase 8",
          "name": "Visual Regression",
          "command": "npm run test:phase8",
          "required": false,
          "allowWarnings": true
        }
      ]
    },
    {
      "suiteKey": "release-with-crawl",
      "name": "Release Regression with Crawler",
      "description": "Release regression plus non-blocking crawler and crawler-derived Phase 6 validation.",
      "defaultTimeoutMs": 3600000,
      "extends": "release",
      "additionalSteps": [
        {
          "phase": "Crawler",
          "name": "Player Standings Crawler",
          "command": "npm run crawl:standings",
          "required": false,
          "allowWarnings": true
        },
        {
          "phase": "Crawler",
          "name": "Generate Phase 6 Fixtures",
          "command": "npm run generate:phase6-fixtures",
          "required": false,
          "allowWarnings": true
        },
        {
          "phase": "Phase 6",
          "name": "Data / API Integrity with Crawler Data",
          "command": "npm run test:phase6",
          "required": false,
          "allowWarnings": true,
          "env": {
            "DATA_SOURCE": "crawler"
          }
        }
      ]
    }
  ]
}
